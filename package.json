{
  "name": "altiplano",
  "displayName": "Altiplano",
  "description": "AL code dependency visualizer",
  "version": "0.0.1",
  "publisher": "alexander-drogin",
  "author": {
    "name": "Alexander Drogin"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Formatters"
  ],
  "keywords": [
    "al",
    "code",
    "Business Central",
    "visualizer",
    "architecture diagram"
  ],
  "activationEvents": [
    "onCommand:altiplano.showDependencyDiagram"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "altiplano.showDependencyDiagram",
        "title": "Altiplano: Show Dependency Diagram"
      }
    ],
    "languages": [
      {
        "id": "al",
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package --no-dependencies",
    "package:prod": "npm run compile && vsce package --no-dependencies",
    "package:dev": "npm run compile && vsce package --no-dependencies --allow-star-activation"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "antlr4": "^4.13.2",
    "eslint": "^8.57.1",
    "typescript": "^5.0.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "mermaid": "^11.16.0"
  }
}
