{
  "all": true,
  "include": [
    "plugin/**/*.js"
  ],
  "exclude": [
    "node_modules/**",
    "tests/**",
    "vscode_ext/**",
    "build.js",
    "sampleFormat.js",
    "babel.config.js"
  ],
  "reporter": [
    "text",
    "html",
    "lcov"
  ],
  "report-dir": "./coverage",
  "temp-dir": "./.nyc_output",
  "skip-full": false,
  "produce-source-map": true,
  "extension": [
    ".js"
  ],
  "instrument": true,
  "lines": 80,
  "functions": 80,
  "branches": 80,
  "statements": 80
}
