{
  "version": "0.2.0",
  "configurations": [
    {
        "type": "extensionHost",
        "request": "launch",
        "name": "Launch Extension",
        "args": [
            "--extensionDevelopmentPath=${workspaceFolder}"
        ],
        "outFiles": [
            "${workspaceFolder}/out/**/*.js"
        ],
        "sourceMaps": true,
        "resolveSourceMapLocations": [
            "${workspaceFolder}/**",
            "!**/node_modules/**"
        ],
        "preLaunchTask": "tsc: build - tsconfig.json"
    }
  ]
}